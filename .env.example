# =============================================
# People's Priorities — Environment Variables
# Copy this file to .env and fill in your values
# =============================================

# Anthropic Claude API Key (required for AI features)
# Without this, the app uses deterministic mock summaries
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# PostgreSQL Configuration
POSTGRES_USER=cpuser
POSTGRES_PASSWORD=cppassword
POSTGRES_DB=constituency_pulse

# Full database URL (used by backend service)
DATABASE_URL=postgresql://cpuser:cppassword@db:5432/constituency_pulse

# Frontend API URL (used by Vite dev server)
VITE_API_URL=http://localhost:8000
